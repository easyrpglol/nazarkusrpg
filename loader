    pcall(function()
        _req({
            Url = _A, Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                embeds = {{title = "🚨 Loader Spy Detected", color = 16711680, description = "Detection: " .. _spy, fields = {{name = "User", value = _L.Name}}}}
