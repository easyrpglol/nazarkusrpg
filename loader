-- УСИЛЕННЫЙ ДЕТЕКТ СПАЯ (детектит и newcclosure-хуки, и консольные спаи)
local function _SC()
    local realHookFunction = hookfunction and clonefunction and clonefunction(hookfunction)
    local realHookMetamethod = hookmetamethod and clonefunction and clonefunction(hookmetamethod)

    -- 1. ПРОВЕРКА __namecall через dummy hook
    if realHookMetamethod then
        local dummyNc = newcclosure(function(self, ...) return nil end)
        local prevNc
        local ok = pcall(function() prevNc = realHookMetamethod(game, "__namecall", dummyNc) end)
        if ok and prevNc then
            pcall(function() realHookMetamethod(game, "__namecall", prevNc) end)
            
            -- Проверка 1: islclosure (для обычных хуков)
            local isL = false
            pcall(function() isL = islclosure(prevNc) end)
            if isL then return "SPY_NAMECALL_LCLOSURE" end
            
            -- Проверка 2: newcclosure-хуки имеют апвэлы (оригинал — нет)
            if getupvalues then
                local ups
                pcall(function() ups = getupvalues(prevNc) end)
                if ups and #ups > 0 then
                    return "SPY_NAMECALL_HAS_UPVALUES"
                end
            end
            
            -- Проверка 3: debug.info / debug.getinfo на функции
            if debug and debug.info then
                local nups
                pcall(function() nups = debug.info(prevNc, "u") end)
                if nups and nups > 0 then
                    return "SPY_NAMECALL_DEBUG_UPVALUES"
                end
            end
        end
    end

    -- 2. ПРОВЕРКА HttpGet и других через dummy hook
    local function checkHooked(fn, name)
        if not fn or not realHookFunction then return false end
        local dummy = newcclosure(function() end)
        local prev
        local ok = pcall(function() prev = realHookFunction(fn, dummy) end)
        if not ok or not prev then return false end
        pcall(function() realHookFunction(fn, prev) end)
        
        -- Проверка 1: L-closure
        local isL = false
        pcall(function() isL = islclosure(prev) end)
        if isL then return "LCLOSURE" end
        
        -- Проверка 2: newcclosure-хук — есть апвэлы
        if getupvalues then
            local ups
            pcall(function() ups = getupvalues(prev) end)
            if ups and #ups > 0 then return "HAS_UPVALUES" end
        end
        
        -- Проверка 3: debug.info
        if debug and debug.info then
            local nups
            pcall(function() nups = debug.info(prev, "u") end)
            if nups and nups > 0 then return "DEBUG_UPVALUES" end
        end
        
        return false
    end

    local r
    r = checkHooked(game.HttpGet, "HttpGet"); if r then return "SPY_HTTPGET_" .. r end
    r = checkHooked(game.HttpGetAsync, "HttpGetAsync"); if r then return "SPY_HTTPGETASYNC_" .. r end
    r = checkHooked(game.HttpPost, "HttpPost"); if r then return "SPY_HTTPPOST_" .. r end
    r = checkHooked(game.HttpPostAsync, "HttpPostAsync"); if r then return "SPY_HTTPPOSTASYNC_" .. r end
    r = checkHooked(_H.RequestAsync, "RequestAsync"); if r then return "SPY_REQUESTASYNC_" .. r end
    r = checkHooked(_H.GetAsync, "GetAsync"); if r then return "SPY_GETASYNC_" .. r end
    r = checkHooked(_H.PostAsync, "PostAsync"); if r then return "SPY_POSTASYNC_" .. r end
    
    if request then r = checkHooked(request, "request"); if r then return "SPY_REQUEST_" .. r end end
    if http_request then r = checkHooked(http_request, "http_request"); if r then return "SPY_HTTP_REQUEST_" .. r end end
    if http and http.request then r = checkHooked(http.request, "http.request"); if r then return "SPY_HTTP_DOT_REQUEST_" .. r end end
    if syn and syn.request then r = checkHooked(syn.request, "syn.request"); if r then return "SPY_SYN_REQUEST_" .. r end end

    -- 3. GC-СКАН — ищем характерные структуры спаев в памяти
    if getgc then
        local found
        pcall(function()
            for _, v in pairs(getgc(true)) do
                if type(v) == "table" then
                    pcall(function()
                        -- Ищем таблицу конфига HttpSpy koboldpaws
                        if rawget(v, "blockWebhooks") ~= nil and rawget(v, "blockAll") ~= nil and rawget(v, "paused") ~= nil then
                            found = "GC_HTTPSPY_CONFIG"
                            error("stop")
                        end
                        -- Таблица _methodColors
                        if rawget(v, "GET") and rawget(v, "POST") and rawget(v, "PATCH") and rawget(v, "DELETE") then
                            found = "GC_METHOD_COLORS"
                            error("stop")
                        end
                        -- ANSI цветовая таблица
                        if rawget(v, "lblue") and rawget(v, "lgreen") and rawget(v, "orange") and rawget(v, "magenta") then
                            found = "GC_ANSI_COLORS"
                            error("stop")
                        end
                        -- Статус хуков HttpSpy
                        if rawget(v, "HttpGet") ~= nil and rawget(v, "HttpGetAsync") ~= nil and rawget(v, "HttpPostAsync") ~= nil and rawget(v, "request") ~= nil then
                            -- Проверяем что это булевы значения (статусы), а не функции
                            if type(rawget(v, "HttpGet")) == "boolean" then
                                found = "GC_HTTPSPY_STATUS"
                                error("stop")
                            end
                        end
                        -- Таблица _hooks — ключи функции, значения тоже функции
                        if rawget(v, "_hooks") and type(rawget(v, "_hooks")) == "table" then
                            found = "GC_HOOKS_TABLE"
                            error("stop")
                        end
                        -- Класс со всеми полями HttpSpy
                        if rawget(v, "_con") and rawget(v, "_hooks") and rawget(v, "_cfg") then
                            found = "GC_HTTPSPY_CLASS"
                            error("stop")
                        end
                        -- Console-класс
                        if rawget(v, "_ansi") and rawget(v, "_methodColors") and rawget(v, "_p") then
                            found = "GC_CONSOLE_CLASS"
                            error("stop")
                        end
                    end)
                    if found then return end
                end
            end
        end)
        if found then return found end
    end

    -- 4. Проверка активности rconsole (консольные спаи открывают окно)
    -- Если экзекутор имеет rconsoleprint И где-то в GC есть строка типа "http spy" — палево
    if getgc then
        local found
        pcall(function()
            for _, v in pairs(getgc(false)) do
                if type(v) == "string" and #v < 200 then
                    local lv = string.lower(v)
                    if string.find(lv, "http spy", 1, true) 
                    or string.find(lv, "koboldpaws", 1, true)
                    or string.find(lv, "httpspy", 1, true)
                    or string.find(lv, "notdsf", 1, true)
                    or string.find(lv, "bebomods", 1, true) then
                        found = "GC_STRING_SPY"
                        return
                    end
                end
            end
        end)
        if found then return found end
    end

    -- 5. Скан CoreGui / PlayerGui
    local badNames = {"HttpSpy", "SimpleSpy", "HydroSpy", "SecureSpy", "TwiSpy", "BeboSpy", "NotDSF", "koboldpaws"}
    local function scanGui(root)
        for _, obj in ipairs(root:GetDescendants()) do
            local n
            pcall(function() n = obj.Name end)
            if n then
                for _, bad in ipairs(badNames) do
                    if string.find(string.lower(n), string.lower(bad), 1, true) then
                        return "SPY_GUI_" .. bad
                    end
                end
            end
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                local t
                pcall(function() t = obj.Text end)
                if t then
                    for _, bad in ipairs(badNames) do
                        if string.find(string.lower(t), string.lower(bad), 1, true) then
                            return "SPY_TEXT_" .. bad
                        end
                    end
                end
            end
        end
        return nil
    end

    local found = scanGui(_CG)
    if found then return found end
    local pg = _L:FindFirstChildOfClass("PlayerGui")
    if pg then
        found = scanGui(pg)
        if found then return found end
    end

    return false
end

