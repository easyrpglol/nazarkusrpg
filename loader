local _realHookFunction = hookfunction and clonefunction and clonefunction(hookfunction)
local _realHookMetamethod = hookmetamethod and clonefunction and clonefunction(hookmetamethod)
local _isLC = islclosure

-- Кэшируем ссылки на функции
local _fns = {
    {game.HttpGet, "HTTPGET"},
    {game.HttpGetAsync, "HTTPGETASYNC"},
    {game.HttpPost, "HTTPPOST"},
    {game.HttpPostAsync, "HTTPPOSTASYNC"},
