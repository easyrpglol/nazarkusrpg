-- УСИЛЕННЫЙ ДЕТЕКТ СПАЯ
local function _SC()
    -- 1. Проверка хуков через iscclosure (самый надёжный способ)
    if iscclosure and islclosure then
        -- game.HttpGet должна быть C-функцией
        local ok, isL = pcall(islclosure, game.HttpGet)
        if ok and isL then return "HOOKED_HTTPGET_LCLOSURE" end
        
        -- HttpService методы
        local ok2, isL2 = pcall(islclosure, _H.RequestAsync)
        if ok2 and isL2 then return "HOOKED_REQUESTASYNC_LCLOSURE" end
        
        local ok3, isL3 = pcall(islclosure, _H.GetAsync)
        if ok3 and isL3 then return "HOOKED_GETASYNC_LCLOSURE" end
        
        -- Глобальные функции запросов
        if request then
            local ok4, isL4 = pcall(islclosure, request)
            if ok4 and isL4 then return "HOOKED_REQUEST_LCLOSURE" end
        end
        if http_request then
            local ok5, isL5 = pcall(islclosure, http_request)
            if ok5 and isL5 then return "HOOKED_HTTP_REQUEST_LCLOSURE" end
        end
        if http and http.request then
            local ok6, isL6 = pcall(islclosure, http.request)
            if ok6 and isL6 then return "HOOKED_HTTP_DOT_REQUEST_LCLOSURE" end
        end
        if syn and syn.request then
            local ok7, isL7 = pcall(islclosure, syn.request)
            if ok7 and isL7 then return "HOOKED_SYN_REQUEST_LCLOSURE" end
        end
    end

    -- 2. Проверка через getoriginalfunction (если хукнута — вернёт другую функцию)
    if getoriginalfunction then
        local ok, orig = pcall(getoriginalfunction, game.HttpGet)
        if ok and orig and orig ~= game.HttpGet then
            return "HOOKED_HTTPGET_ORIGINAL"
        end
    end

    -- 3. Проверка через debug.getinfo
    local ok, info = pcall(debug.getinfo, game.HttpGet)
    if ok and info and info.source and info.source ~= "=[C]" then
        return "HOOKED_HTTPGET_SOURCE"
    end

    -- 4. Сканирование CoreGui — ищем всё что связано с HttpSpy/Spy
    local badNames = {"HttpSpy", "SimpleSpy", "HydroSpy", "SecureSpy", "VGG Spy", "TwiSpy", "Spidey", "BeboSpy", "NotDSF"}
    for _, obj in ipairs(_CG:GetDescendants()) do
        local ok, name = pcall(function() return obj.Name end)
        if ok and name then
            for _, bad in ipairs(badNames) do
                if string.find(string.lower(name), string.lower(bad)) then
                    return "SPY_GUI_" .. bad
                end
            end
        end
        -- Проверяем текст в TextLabel/TextButton
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then
            local ok2, txt = pcall(function() return obj.Text end)
            if ok2 and txt then
                for _, bad in ipairs(badNames) do
                    if string.find(string.lower(txt), string.lower(bad)) then
                        return "SPY_TEXT_" .. bad
                    end
                end
            end
        end
    end

    -- 5. Проверка PlayerGui тоже
    local pg = _L:FindFirstChildOfClass("PlayerGui")
    if pg then
        for _, obj in ipairs(pg:GetDescendants()) do
            local ok, name = pcall(function() return obj.Name end)
            if ok and name then
                for _, bad in ipairs(badNames) do
                    if string.find(string.lower(name), string.lower(bad)) then
                        return "SPY_PGUI_" .. bad
                    end
                end
            end
        end
    end

    -- 6. Проверка глобальной среды на подозрительные ключи
    if getgenv then
        local env = getgenv()
        local badGlobals = {"HttpSpy", "SimpleSpy", "SpyLogs", "SpyLoaded", "__SPY__", "SPY_ACTIVE"}
        for _, key in ipairs(badGlobals) do
            if env[key] ~= nil then return "SPY_GLOBAL_" .. key end
        end
    end

    -- 7. Проверка через getgc — ищем скрипты с характерными строками спая
    if getgc then
        local ok = pcall(function()
            for _, v in pairs(getgc(true)) do
                if type(v) == "table" then
                    local hasUrl, hasBody, hasMethod = false, false, false
                    pcall(function()
                        for k, _ in pairs(v) do
                            if type(k) == "string" then
                                local lk = string.lower(k)
                                if lk == "requestlist" or lk == "requestlog" or lk == "logrequest" then
                                    error("SPY_TABLE_" .. k)
                                end
                            end
                        end
                    end)
                end
            end
        end)
    end

    -- 8. Проверка хуков через checkcaller/hookfunction идентичность
    if hookfunction and clonefunction then
        local ok, clone = pcall(clonefunction, game.HttpGet)
        if ok and clone then
            local ok2, isC = pcall(iscclosure, clone)
            local ok3, isCorig = pcall(iscclosure, game.HttpGet)
            if ok2 and ok3 and isC ~= isCorig then
                return "HOOKED_HTTPGET_MISMATCH"
            end
        end
    end

    return false
end

