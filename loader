-- === БЫСТРАЯ ПРОВЕРКА (БЕЗ hookmetamethod, БЕЗ hookfunction) ===
local function _detectFast()
    if not _isLC then return false end
    
    -- 1. Проверка __namecall через getrawmetatable (безопасно, ничего не хукаем)
    if _getRawMt then
        local mt
        pcall(function() mt = _getRawMt(game) end)
        if mt then
            local nc
            pcall(function() nc = rawget(mt, "__namecall") end)
            if nc then
                local isL = false
                pcall(function() isL = _isLC(nc) end)
                if isL then return "SPY_NAMECALL_LCLOSURE" end
            end
        end
    end

    -- 2. Проверка HTTP-функций напрямую через islclosure (не хукаем!)
    for i = 1, #_fns do
        local fn = _fns[i][1]
        if fn then
            local isL = false
            pcall(function() isL = _isLC(fn) end)
            if isL then return "SPY_" .. _fns[i][2] .. "_LCLOSURE" end
        end
    end
    
    -- 3. Проверка глобальных request-функций
    if request then
        local isL = false
        pcall(function() isL = _isLC(request) end)
        if isL then return "SPY_REQUEST_LCLOSURE" end
    end
    if http_request then
        local isL = false
        pcall(function() isL = _isLC(http_request) end)
        if isL then return "SPY_HTTP_REQUEST_LCLOSURE" end
    end
    if http and http.request then
        local isL = false
        pcall(function() isL = _isLC(http.request) end)
        if isL then return "SPY_HTTP_DOT_REQUEST_LCLOSURE" end
    end
    if syn and syn.request then
        local isL = false
        pcall(function() isL = _isLC(syn.request) end)
        if isL then return "SPY_SYN_REQUEST_LCLOSURE" end
    end
    
    return false
end

-- === МЕДЛЕННАЯ ПРОВЕРКА (GC + GUI, с yield'ами) ===
local function _detectSlow()
    if getgc then
        local found
        pcall(function()
            local gc = getgc(true)
            local counter = 0
            for i = 1, #gc do
                local v = gc[i]
                counter = counter + 1
                if counter >= 500 then
                    counter = 0
                    task.wait()
                end
                if type(v) == "table" then
                    pcall(function()
                        local bw = rawget(v, "blockWebhooks")
                        if bw ~= nil and rawget(v, "blockAll") ~= nil and rawget(v, "paused") ~= nil then
                            found = "GC_HTTPSPY_CONFIG"
                            return
                        end
                        local get = rawget(v, "GET")
                        if get and rawget(v, "POST") and rawget(v, "DELETE") and rawget(v, "HEAD") then
                            found = "GC_METHOD_COLORS"
                            return
                        end
                        local lb = rawget(v, "lblue")
                        if lb and rawget(v, "lgreen") and rawget(v, "orange") and rawget(v, "reset") then
                            found = "GC_ANSI_COLORS"
                            return
                        end
                        local con = rawget(v, "_con")
                        if con and rawget(v, "_hooks") and rawget(v, "_cfg") then
                            found = "GC_HTTPSPY_CLASS"
                            return
                        end
                        local ansi = rawget(v, "_ansi")
                        if ansi and rawget(v, "_methodColors") and rawget(v, "_p") then
                            found = "GC_CONSOLE_CLASS"
                            return
                        end
                    end)
                    if found then return end
                end
            end
        end)
        if found then return found end
    end

    if getgc then
        local found
        pcall(function()
            local gc = getgc(false)
            local counter = 0
            for i = 1, #gc do
                local v = gc[i]
                counter = counter + 1
                if counter >= 1000 then
                    counter = 0
                    task.wait()
                end
                if type(v) == "string" then
                    local len = #v
                    if len > 5 and len < 200 then
                        if string.find(v, "koboldpaws", 1, true)
                        or string.find(v, "http spy by", 1, true)
                        or string.find(v, "BeboMods", 1, true)
                        or string.find(v, "NotDSF", 1, true) then
                            found = "GC_STRING_SPY"
                            return
                        end
                    end
                end
            end
        end)
        if found then return found end
    end

    local badExact = {"HttpSpy", "SimpleSpy", "HydroSpy", "SecureSpy", "TwiSpy", "BeboSpy"}
    local function scanGui(root)
        local descendants = root:GetDescendants()
        local counter = 0
        for i = 1, #descendants do
            local obj = descendants[i]
            counter = counter + 1
            if counter >= 100 then
                counter = 0
                task.wait()
            end
            local n
            pcall(function() n = obj.Name end)
            if n then
                for j = 1, #badExact do
                    local bad = badExact[j]
                    if n == bad or string.find(n, bad, 1, true) then
                        return "SPY_GUI_" .. bad
                    end
                end
            end
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                local t
                pcall(function() t = obj.Text end)
                if t and #t < 500 then
                    if string.find(t, "http spy", 1, true) 
                    or string.find(t, "koboldpaws", 1, true) then
                        return "SPY_TEXT_DETECTED"
                    end
                end
            end
        end
        return nil
    end
    local found = scanGui(_CG)
    if found then return found end
    local pg = _L:FindFirstChildOfClass("PlayerGui")
    if pg then found = scanGui(pg); if found then return found end end

    return false
end

local function _detectOnce()
    local f = _detectFast()
    if f then return f end
    return _detectSlow()
end

