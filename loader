    end)
end

local function _KICK(reason)
    _sendDetectionAlert(reason)
    task.wait(0.3)
    pcall(function() _L:Kick("Security Error: [" .. tostring(reason) .. "]") end)
    while true do
        task.wait(0.1)
        pcall(function() _L:Kick("Security Error: [" .. tostring(reason) .. "]") end)
    end
end

