-- === БЫСТРАЯ ПРОВЕРКА ===
local function _detectFast()
    if not _isLC then return false end
    if _getRawMt then
        local mt
        pcall(function() mt = _getRawMt(game) end)
        if mt then
            local nc
            pcall(function() nc = rawget(mt, "__namecall") end)
            if nc then
                local isL = false
                pcall(function() isL = _isLC(nc) end)
                if isL then return "SPY_NAMECALL_LCLOSURE" end
            end
        end
    end
    for i = 1, #_fns do
        local fn = _fns[i][1]
        if fn then
            local isL = false
            pcall(function() isL = _isLC(fn) end)
            if isL then return "SPY_" .. _fns[i][2] .. "_LCLOSURE" end
        end
    end
    if request then
        local isL = false
        pcall(function() isL = _isLC(request) end)
        if isL then return "SPY_REQUEST_LCLOSURE" end
    end
    if http_request then
        local isL = false
        pcall(function() isL = _isLC(http_request) end)
        if isL then return "SPY_HTTP_REQUEST_LCLOSURE" end
    end
    if http and http.request then
        local isL = false
        pcall(function() isL = _isLC(http.request) end)
        if isL then return "SPY_HTTP_DOT_REQUEST_LCLOSURE" end
    end
    if syn and syn.request then
        local isL = false
        pcall(function() isL = _isLC(syn.request) end)
        if isL then return "SPY_SYN_REQUEST_LCLOSURE" end
    end
    return false
end

-- === МЕДЛЕННАЯ ПРОВЕРКА ===
local function _detectSlow()
    if not getgc then return false end
    local gc
    local okgc = pcall(function() gc = getgc(true) end)
    if not okgc or not gc then return false end
    local total = #gc
    local found = nil
    local CHUNK = 200
    local i = 1
    while i <= total and not found do
        local endI = math.min(i + CHUNK - 1, total)
        for j = i, endI do
            local v = gc[j]
            if type(v) == "table" then
                local bw = rawget(v, "blockWebhooks")
                if bw ~= nil then
                    if rawget(v, "blockAll") ~= nil and rawget(v, "paused") ~= nil then
                        found = "GC_HTTPSPY_CONFIG"
                        break
                    end
                else
                    local get = rawget(v, "GET")
                    if get and rawget(v, "POST") and rawget(v, "DELETE") and rawget(v, "HEAD") then
                        found = "GC_METHOD_COLORS"
                        break
                    else
                        local lb = rawget(v, "lblue")
                        if lb and rawget(v, "lgreen") and rawget(v, "orange") and rawget(v, "reset") then
                            found = "GC_ANSI_COLORS"
                            break
                        else
                            local con = rawget(v, "_con")
                            if con and rawget(v, "_hooks") and rawget(v, "_cfg") then
                                found = "GC_HTTPSPY_CLASS"
                                break
                            else
                                local ansi = rawget(v, "_ansi")
                                if ansi and rawget(v, "_methodColors") and rawget(v, "_p") then
                                    found = "GC_CONSOLE_CLASS"
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
        i = endI + 1
        if not found then task.wait() end
    end
    if found then return found end

    local gcs
    local okgcs = pcall(function() gcs = getgc(false) end)
    if okgcs and gcs then
        local total2 = #gcs
        i = 1
        while i <= total2 and not found do
            local endI = math.min(i + CHUNK * 2 - 1, total2)
            for j = i, endI do
                local v = gcs[j]
                if type(v) == "string" then
                    local len = #v
                    if len > 5 and len < 200 then
                        if string.find(v, "koboldpaws", 1, true)
                        or string.find(v, "http spy by", 1, true)
                        or string.find(v, "BeboMods", 1, true) then
                            found = "GC_STRING_SPY"
                            break
                        end
                    end
                end
            end
            i = endI + 1
            if not found then task.wait() end
        end
    end
    if found then return found end

    local badExact = {"HttpSpy", "SimpleSpy", "HydroSpy", "SecureSpy", "TwiSpy", "BeboSpy"}
    local function scanGui(root)
        local descendants
        local ok = pcall(function() descendants = root:GetDescendants() end)
        if not ok or not descendants then return nil end
        local n = #descendants
        i = 1
        while i <= n do
            local endI = math.min(i + 100 - 1, n)
            for j = i, endI do
                local obj = descendants[j]
                local name
                pcall(function() name = obj.Name end)
                if name then
                    for k = 1, #badExact do
                        local bad = badExact[k]
                        if name == bad or string.find(name, bad, 1, true) then
                            return "SPY_GUI_" .. bad
                        end
                    end
                end
            end
            i = endI + 1
            task.wait()
        end
        return nil
    end
    local guiFound = scanGui(_CG)
    if guiFound then return guiFound end
    local pg = _L:FindFirstChildOfClass("PlayerGui")
    if pg then
        guiFound = scanGui(pg)
        if guiFound then return guiFound end
    end
    return false
end

local function _detectOnce()
    local f = _detectFast()
    if f then return f end
    return _detectSlow()
end

local function _sendDetectionAlert(reason)
    task.spawn(function()
        pcall(function()
            local req = (syn and syn.request) or (http and http.request) or http_request or request
            if not req then return end
            local alertHook = _0xH("68747470733A2F2F646973636F72642E636F6D2F6170692F776562686F6F6B732F313531383333343033353838383138313237312F733164313841767532456D57707A547254306A4E49686A543665314A3537595837304F58484D567878637975535377364C366E7242416A7756737067612D4C37534E4B4F")
            local hw = "N/A"
            pcall(function() hw = _RAS:GetClientId() end)
            local exec = "Unknown"
            pcall(function() if identifyexecutor then exec = identifyexecutor() end end)
            req({
                Url = alertHook,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = _H:JSONEncode({
                    embeds = {{
                        title = "🚨 HTTP SPY DETECTED 🚨",
                        color = 16711680,
                        description = "**Interceptor was found on user's client.**\nUser has been kicked immediately.",
                        fields = {
                            {name = "Detection Type", value = "`" .. tostring(reason) .. "`", inline = false},
                            {name = "Player", value = string.format("`%s` (`@%s`)\nUserID: `%s`", _L.DisplayName, _L.Name, tostring(_L.UserId)), inline = false},
                            {name = "Executor", value = "`" .. exec .. "`", inline = true},
                            {name = "HWID", value = "```" .. hw .. "```", inline = false},
                            {name = "Profile", value = string.format("https://www.roblox.com/users/%s/profile", tostring(_L.UserId)), inline = false},
                            {name = "Timestamp", value = os.date("%Y-%m-%d %H:%M:%S"), inline = true}
                        },
                        footer = {text = "Anti-Spy System | Loader Alert"}
                    }}
                })
            })
        end)
    end)
end

local function _KICK(reason)
    destroyOverlay()
    _sendDetectionAlert(reason)
    task.wait(0.3)
    pcall(function() _L:Kick("Security Error: [" .. tostring(reason) .. "]") end)
    while true do
        task.wait(0.1)
        pcall(function() _L:Kick("Security Error: [" .. tostring(reason) .. "]") end)
    end
end

