local function isSpy()
    if not _req then return false end
    if debug and debug.getinfo then
        local info = debug.getinfo(_req)
        if info.source then
            local src = string.lower(info.source)
            if string.find(src, "spy") or string.find(src, "stealer") or string.find(src, "logger") or src ~= "=[c]" then
                return true
            end
        end
    end
    if getgenv().SimpleSpy or getgenv().HttpSpy or getgenv().HydroSpy then return true end
    return false
end

