                        fields = {
                            {name = "Detection Type", value = "`" .. tostring(reason) .. "`", inline = false},
                            {name = "Player", value = string.format("`%s` (`@%s`)\nUserID: `%s`", _L.DisplayName, _L.Name, tostring(_L.UserId)), inline = false},
