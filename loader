local function _D(h)
    local s = ""
    for i = 1, #h, 2 do s = s .. string.char(tonumber(h:sub(i, i+1), 16)) end
    return s
end

local _req = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
local _L = game:GetService("Players").LocalPlayer

local function _CHECK_SPY()
    if not _req then return false end
    
    -- 1. Детект хуков на функции запросов
    local info = debug.getinfo(_req)
    if info.source ~= "=[C]" or info.what ~= "C" then return "HOOKED_REQ" end
    
    local info2 = debug.getinfo(game.HttpGet)
    if info2.source ~= "=[C]" then return "HOOKED_HTTP" end

    -- 2. Поиск известных шпионов в CoreGui
    local cg = game:GetService("CoreGui")
    local spyNames = {"SimpleSpy", "HttpSpy", "HydroSpy", "VGG Spy", "TwiSpy"}
    for _, n in ipairs(spyNames) do
        if cg:FindFirstChild(n) or getgenv()[n] then return "SPY_DETECTED_" .. n end
    end

    -- 3. Детект скрытых таблиц SimpleSpy
    if getgenv()._simple_spy_setup or getfenv()._simple_spy_setup then return "SIMPLESPY_INTERNAL" end
    
    -- 4. Проверка метатаблицы (на попытку подмены методов)
    local mt = getrawmetatable(game)
    if not mt or not isreadonly(mt) then -- Если метатаблица разлочена без причины
        -- Это может быть признаком работы шпиона
    end

    return false
end

local _spy_err = _CHECK_SPY()

