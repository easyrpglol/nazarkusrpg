local function _D(h)
    local s = ""
    for i = 1, #h, 2 do s = s .. string.char(tonumber(h:sub(i, i+1), 16)) end
    return s
end

local _req = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
local _L = game:GetService("Players").LocalPlayer

local function _CHECK_SPY()
    if not _req then return false end
    local info = debug.getinfo(_req)
    if info.source ~= "=[C]" or info.what ~= "C" then return "HOOKED_REQ" end
    if debug.getinfo(game.HttpGet).source ~= "=[C]" then return "HOOKED_HTTP" end
    local cg = game:GetService("CoreGui")
    for _, n in ipairs({"SimpleSpy", "HttpSpy", "HydroSpy", "VGG Spy"}) do
        if cg:FindFirstChild(n) or getgenv()[n] then return "SPY_" .. n end
    end
    return false
end

local _spy = _CHECK_SPY()
