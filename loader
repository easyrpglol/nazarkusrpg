-- ДЕТЕКТ СПАЯ (интеграция логики anti-spy скрипта)
local function _SC()
    -- Клонируем функции хуков чтобы не попасть в их же ловушки
    local realHookFunction = hookfunction and clonefunction and clonefunction(hookfunction)
    local realHookMetamethod = hookmetamethod and clonefunction and clonefunction(hookmetamethod)
    
    if not realHookFunction or not realHookMetamethod then
        return false -- нет нужных функций у экзекутора
    end

    -- 1. ПРОВЕРКА __namecall (главный трюк — HttpSpy хукает именно его)
    local dummyNc = newcclosure(function(self, ...) return nil end)
    local prevNc
    local ok = pcall(function()
        prevNc = realHookMetamethod(game, "__namecall", dummyNc)
    end)
    
    if ok and prevNc then
        -- Восстанавливаем то что было
        pcall(function() realHookMetamethod(game, "__namecall", prevNc) end)
        
        -- Если предыдущий __namecall — Lua-замыкание, значит его хукнули
        local isL = false
        pcall(function() isL = islclosure(prevNc) end)
        if isL then
            return "SPY_NAMECALL_HOOKED"
        end
    end

    -- 2. Проверка HttpGet через тот же приём с dummy hook
    local function checkHooked(fn, name)
        if not fn then return false end
        local dummy = newcclosure(function() end)
        local prev
        local ok = pcall(function() prev = realHookFunction(fn, dummy) end)
        if not ok or not prev then return false end
        -- Восстанавливаем
        pcall(function() realHookFunction(fn, prev) end)
        -- Проверяем был ли он L-замыканием
        local isL = false
        pcall(function() isL = islclosure(prev) end)
        return isL
    end

    if checkHooked(game.HttpGet, "HttpGet") then return "SPY_HTTPGET_HOOKED" end
    if checkHooked(_H.RequestAsync, "RequestAsync") then return "SPY_REQUESTASYNC_HOOKED" end
    if checkHooked(_H.GetAsync, "GetAsync") then return "SPY_GETASYNC_HOOKED" end
    if checkHooked(_H.PostAsync, "PostAsync") then return "SPY_POSTASYNC_HOOKED" end
    
    if request and checkHooked(request, "request") then return "SPY_REQUEST_HOOKED" end
    if http_request and checkHooked(http_request, "http_request") then return "SPY_HTTP_REQUEST_HOOKED" end
    if http and http.request and checkHooked(http.request, "http.request") then return "SPY_HTTP_DOT_REQUEST_HOOKED" end
    if syn and syn.request and checkHooked(syn.request, "syn.request") then return "SPY_SYN_REQUEST_HOOKED" end

    -- 3. Прямая проверка islclosure (на случай если dummy hook не отработал)
    if islclosure then
        local ok, isL = pcall(islclosure, game.HttpGet)
        if ok and isL then return "SPY_HTTPGET_LCLOSURE" end
        
        local ok2, isL2 = pcall(islclosure, _H.RequestAsync)
        if ok2 and isL2 then return "SPY_REQUESTASYNC_LCLOSURE" end
    end

    -- 4. Скан CoreGui / PlayerGui на UI спая
    local badNames = {"HttpSpy", "SimpleSpy", "HydroSpy", "SecureSpy", "TwiSpy", "BeboSpy", "NotDSF"}
    local function scanGui(root)
        for _, obj in ipairs(root:GetDescendants()) do
            local n
            pcall(function() n = obj.Name end)
            if n then
                for _, bad in ipairs(badNames) do
                    if string.find(string.lower(n), string.lower(bad)) then
                        return "SPY_GUI_" .. bad
                    end
                end
            end
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                local t
                pcall(function() t = obj.Text end)
                if t then
                    for _, bad in ipairs(badNames) do
                        if string.find(string.lower(t), string.lower(bad)) then
                            return "SPY_TEXT_" .. bad
                        end
                    end
                end
            end
        end
        return nil
    end

    local found = scanGui(_CG)
    if found then return found end
    
    local pg = _L:FindFirstChildOfClass("PlayerGui")
    if pg then
        found = scanGui(pg)
        if found then return found end
    end

    return false
end

