local function _SC()
    if not _req then return false end
    local ok, info = pcall(debug.getinfo, _req)
    if ok and info and (info.source ~= "=[C]" or info.what ~= "C") then return "HOOKED_REQUEST" end
    local ok2, hooked2 = pcall(function()
        local i = debug.getinfo(game.HttpGet)
        return i.source ~= "=[C]"
    end)
    if ok2 and hooked2 then return "HOOKED_HTTPGET" end
    local cg = game:GetService("CoreGui")
    for _, n in ipairs({"SimpleSpy", "HttpSpy", "HydroSpy", "VGG Spy", "TwiSpy"}) do
        if cg:FindFirstChild(n) or (getgenv and getgenv()[n]) then return "SPY_DETECTED_" .. n end
    end
    return false
end

