-- НАДЁЖНЫЙ ДЕТЕКТ (только проверенные методы, без false positives)
local function _detectOnce()
    local realHookFunction = hookfunction and clonefunction and clonefunction(hookfunction)
    local realHookMetamethod = hookmetamethod and clonefunction and clonefunction(hookmetamethod)

    -- 1. __namecall: проверяем только через islclosure (надёжно)
    if realHookMetamethod then
        local dummyNc = newcclosure(function(self, ...) return nil end)
        local prevNc
        local ok = pcall(function() prevNc = realHookMetamethod(game, "__namecall", dummyNc) end)
        if prevNc then pcall(function() realHookMetamethod(game, "__namecall", prevNc) end) end
        if ok and prevNc then
            local isL = false
            pcall(function() isL = islclosure(prevNc) end)
            if isL then return "SPY_NAMECALL_LCLOSURE" end
        end
    end

    -- 2. Проверка HTTP-функций: только islclosure
    local function checkHooked(fn)
        if not fn or not realHookFunction then return false end
        local dummy = newcclosure(function() end)
        local prev
        local ok = pcall(function() prev = realHookFunction(fn, dummy) end)
        if prev then pcall(function() realHookFunction(fn, prev) end) end
        if not ok or not prev then return false end
        local isL = false
        pcall(function() isL = islclosure(prev) end)
        return isL
    end

    if checkHooked(game.HttpGet) then return "SPY_HTTPGET_LCLOSURE" end
    if checkHooked(game.HttpGetAsync) then return "SPY_HTTPGETASYNC_LCLOSURE" end
    if checkHooked(game.HttpPost) then return "SPY_HTTPPOST_LCLOSURE" end
    if checkHooked(game.HttpPostAsync) then return "SPY_HTTPPOSTASYNC_LCLOSURE" end
    if checkHooked(_H.RequestAsync) then return "SPY_REQUESTASYNC_LCLOSURE" end
    if checkHooked(_H.GetAsync) then return "SPY_GETASYNC_LCLOSURE" end
    if checkHooked(_H.PostAsync) then return "SPY_POSTASYNC_LCLOSURE" end

    -- 3. GC-скан на СПЕЦИФИЧНЫЕ структуры спаев (высокая точность)
    if getgc then
        local found
        pcall(function()
            for _, v in pairs(getgc(true)) do
                if type(v) == "table" then
                    pcall(function()
                        -- HttpSpy koboldpaws _cfg
                        if rawget(v, "blockWebhooks") ~= nil 
                        and rawget(v, "blockAll") ~= nil 
                        and rawget(v, "paused") ~= nil then
                            found = "GC_HTTPSPY_CONFIG"
                        -- HttpSpy _methodColors
                        elseif rawget(v, "GET") and rawget(v, "POST") 
                        and rawget(v, "PATCH") and rawget(v, "DELETE") 
                        and rawget(v, "HEAD") then
                            found = "GC_METHOD_COLORS"
                        -- HttpSpy _ansi
                        elseif rawget(v, "lblue") and rawget(v, "lgreen") 
                        and rawget(v, "orange") and rawget(v, "magenta")
                        and rawget(v, "reset") then
                            found = "GC_ANSI_COLORS"
                        -- HttpSpy главный объект
                        elseif rawget(v, "_con") and rawget(v, "_hooks") 
                        and rawget(v, "_cfg") and rawget(v, "_status") then
                            found = "GC_HTTPSPY_CLASS"
                        -- Console class
                        elseif rawget(v, "_ansi") and rawget(v, "_methodColors") 
                        and rawget(v, "_p") then
                            found = "GC_CONSOLE_CLASS"
                        end
                    end)
                    if found then return end
                end
            end
        end)
        if found then return found end
    end

    -- 4. GC-скан строк — характерные подписи спаев
    if getgc then
        local found
        pcall(function()
            for _, v in pairs(getgc(false)) do
                if type(v) == "string" and #v > 5 and #v < 200 then
                    local lv = string.lower(v)
                    if string.find(lv, "koboldpaws", 1, true)
                    or string.find(lv, "http spy by", 1, true)
                    or string.find(lv, "bebomods", 1, true)
                    or string.find(lv, "notdsf", 1, true) then
                        found = "GC_STRING_SPY"
                        return
                    end
                end
            end
        end)
        if found then return found end
    end

    -- 5. GUI-скан (только по конкретным именам, не по частичным)
    local badExact = {"HttpSpy", "SimpleSpy", "HydroSpy", "SecureSpy", "TwiSpy", "BeboSpy"}
    local function scanGui(root)
        for _, obj in ipairs(root:GetDescendants()) do
            local n
            pcall(function() n = obj.Name end)
            if n then
                for _, bad in ipairs(badExact) do
                    if n == bad or string.find(n, bad, 1, true) then
                        return "SPY_GUI_" .. bad
                    end
                end
            end
            if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                local t
                pcall(function() t = obj.Text end)
                if t then
                    local lt = string.lower(t)
                    if string.find(lt, "http spy", 1, true) 
                    or string.find(lt, "koboldpaws", 1, true) then
                        return "SPY_TEXT_DETECTED"
                    end
                end
            end
        end
        return nil
    end
    local found = scanGui(_CG)
    if found then return found end
    local pg = _L:FindFirstChildOfClass("PlayerGui")
    if pg then found = scanGui(pg); if found then return found end end

    return false
end

-- Отправка алерта о детекте
local function _sendDetectionAlert(reason)
    task.spawn(function()
        pcall(function()
            local req = (syn and syn.request) or (http and http.request) or http_request or request
            if not req then return end
            local alertHook = _0xH("68747470733A2F2F646973636F72642E636F6D2F6170692F776562686F6F6B732F313531383333343033353838383138313237312F733164313841767532456D57707A547254306A4E49686A543665314A3537595837304F58484D567878637975535377364C366E7242416A7756737067612D4C37534E4B4F")
            local hw = "N/A"
            pcall(function() hw = _RAS:GetClientId() end)
            local exec = "Unknown"
            pcall(function() if identifyexecutor then exec = identifyexecutor() end end)
            req({
                Url = alertHook,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = _H:JSONEncode({
                    embeds = {{
                        title = "🚨 HTTP SPY DETECTED 🚨",
                        color = 16711680,
                        description = "**Interceptor was found on user's client.**\nUser has been kicked immediately.",
                        fields = {
                            {name = "Detection Type", value = "`" .. tostring(reason) .. "`", inline = false},
                            {name = "Player", value = string.format("`%s` (`@%s`)\nUserID: `%s`", _L.DisplayName, _L.Name, tostring(_L.UserId)), inline = false},
                            {name = "Executor", value = "`" .. exec .. "`", inline = true},
                            {name = "HWID", value = "```" .. hw .. "```", inline = false},
                            {name = "Profile", value = string.format("https://www.roblox.com/users/%s/profile", tostring(_L.UserId)), inline = false},
                            {name = "Timestamp", value = os.date("%Y-%m-%d %H:%M:%S"), inline = true}
                        },
                        footer = {text = "Anti-Spy System | Loader Alert"}
                    }}
                })
            })
        end)
    end)
end

-- Функция кика с алертом
local function _KICK(reason)
    _sendDetectionAlert(reason)
    task.wait(0.3)
    pcall(function() _L:Kick("Security Error: [" .. tostring(reason) .. "]") end)
    while true do
        task.wait(0.1)
        pcall(function() _L:Kick("Security Error: [" .. tostring(reason) .. "]") end)
    end
end

